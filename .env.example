# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Inbox for contact form leads (default: sales@digirestro.ai). Comma-separated for multiple.
CONTACT_EMAIL_TO=sales@digirestro.ai

# Sender address — MUST match a domain you verified in Resend (resend.com/domains).
#
# Important: "Digirestro Website <onboarding@resend.dev>" only sends to YOUR Resend
# account email, not to sales@digirestro.ai. To deliver to sales@digirestro.ai:
#   1. Add and verify digirestro.ai in Resend (DNS TXT + DKIM records).
#   2. Set FROM to any address on that domain, for example:
RESEND_FROM=Digirestro <noreply@digirestro.ai>
